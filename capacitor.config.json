{
  "appId": "com.frogrush.game",
  "appName": "Frog Rush 2",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#020b18",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": true,
      "androidSpinnerStyle": "large",
      "spinnerColor": "#22d3ee"
    },
    "StatusBar": {
      "style": "DARK"
    }
  }
}
